# Example environment variables for the backend
# Copy this file to .env and fill in your actual values

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password # <-- CHANGE THIS
DB_DATABASE=turbo_template_db

# Prisma uses a single connection URL
DATABASE_URL="postgresql://postgres:your_db_password@localhost:5432/turbo_template_db?schema=public"

# JWT Authentication
JWT_ACCESS_SECRET=change_me_dev_access_secret_at_least_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_at_least_16_chars
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_HOST=localhost

# PostHog analytics
# Get your API key from PostHog (https://app.posthog.com or https://eu.posthog.com)
# Go to Project Settings > Project API Key
POSTHOG_API_KEY=your_posthog_api_key_here

# Superadmin credentials (comma separated list of emails)
SUPERADMIN_EMAILS=superadmin@example.com
